#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

interface_name=$(ynh_app_setting_get --key=interface_name)
qbit_conf_path=$(ynh_app_setting_get --key=qbit_conf_path)

ynh_script_progression "Arrêt et suppression du VPN WireGuard..."

# Arrêt de WireGuard — PostDown nettoie les règles iptables et de routage automatiquement
if systemctl is-active --quiet "wg-quick@$interface_name" 2>/dev/null; then
    systemctl stop "wg-quick@$interface_name"
fi
systemctl disable "wg-quick@$interface_name" --quiet 2>/dev/null || true

# Suppression du fichier de config WireGuard
rm -f "/etc/wireguard/$interface_name.conf"

# Nettoyage défensif des règles iptables (au cas où PostDown ne les aurait pas supprimées)
iptables -t mangle -D OUTPUT -m owner --uid-owner qbittorrent -j MARK --set-mark 0x1 2>/dev/null || true
iptables -D OUTPUT -m owner --uid-owner qbittorrent ! -o "$interface_name" -j REJECT 2>/dev/null || true
iptables -D OUTPUT -m owner --uid-owner qbittorrent -o lo -j ACCEPT 2>/dev/null || true
ip rule del fwmark 0x1 table 100 2>/dev/null || true
ip route del default dev "$interface_name" table 100 2>/dev/null || true

# Réinitialisation du binding qBittorrent
ynh_script_progression "Réinitialisation de l'interface réseau dans qBittorrent..."
if [ -f "$qbit_conf_path" ]; then
    systemctl stop qbittorrent 2>/dev/null || true
    sleep 1
    sed -i '/Session\\Interface=/d' "$qbit_conf_path"
    sed -i '/Session\\InterfaceName=/d' "$qbit_conf_path"
    systemctl start qbittorrent 2>/dev/null || true
fi

ynh_script_progression "Suppression de $app terminée. qBittorrent utilise à nouveau toutes les interfaces réseau."
