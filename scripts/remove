#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

interface_name=$(ynh_app_setting_get --key=interface_name)

ynh_script_progression "Arrêt du VPN et nettoyage..."

# wg-quick stop exécute PostDown qui supprime les règles iptables/routing automatiquement
systemctl stop "wg-quick@${interface_name}" 2>/dev/null || true
systemctl disable "wg-quick@${interface_name}" --quiet 2>/dev/null || true
rm -f "/etc/wireguard/${interface_name}.conf"

# Nettoyage défensif au cas où PostDown n'aurait pas tourné
iptables -t mangle -D OUTPUT -m owner --uid-owner qbittorrent -j MARK --set-mark 0x1 2>/dev/null || true
iptables -D OUTPUT -m owner --uid-owner qbittorrent ! -o "${interface_name}" -j REJECT 2>/dev/null || true
iptables -D OUTPUT -m owner --uid-owner qbittorrent -o lo -j ACCEPT 2>/dev/null || true
ip rule del fwmark 0x1 table 100 2>/dev/null || true

# Reset binding qBittorrent
local qbit_home qbit_conf
qbit_home=$(getent passwd qbittorrent 2>/dev/null | cut -d: -f6)
qbit_conf="${qbit_home}/.config/qBittorrent/qBittorrent.conf"
[ ! -f "$qbit_conf" ] && qbit_conf="/home/yunohost.app/qbittorrent/.config/qBittorrent/qBittorrent.conf"

if [ -f "$qbit_conf" ]; then
    systemctl stop qbittorrent 2>/dev/null || true
    sleep 1
    sed -i '/Session\\Interface=/d' "$qbit_conf"
    sed -i '/Session\\InterfaceName=/d' "$qbit_conf"
    systemctl start qbittorrent 2>/dev/null || true
fi

ynh_script_progression "Suppression terminée. qBittorrent utilise à nouveau toutes les interfaces."
